{
  "name": "web",
  "location": "apps/web",
  "vars": {
    "NEXT_PUBLIC_API_URL": "${API_URL}",
    "NEXT_PUBLIC_APP_NAME": "${APP_NAME}",
    "NEXT_PUBLIC_SESSION_TTL": "${auth.SESSION_TTL}"
  },
  "defaults": {
    "NEXT_PUBLIC_API_URL": "http://localhost:4000",
    "NEXT_PUBLIC_APP_NAME": "MyApp"
  },
  "dev": {
    "command": "pnpm dev",
    "label": "Web App"
  }
}
