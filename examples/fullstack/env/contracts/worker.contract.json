{
  "name": "worker",
  "location": "apps/worker",
  "vars": {
    "DATABASE_URL": "${database.URL}",
    "REDIS_URL": "${redis.URL}",
    "STORAGE_ACCESS_KEY": "${storage.S3_ACCESS_KEY}",
    "STORAGE_SECRET_KEY": "${storage.S3_SECRET_KEY}",
    "STORAGE_BUCKET": "${storage.S3_BUCKET}",
    "STORAGE_REGION": "${storage.S3_REGION}",
    "MAX_FILE_SIZE": "${storage.MAX_FILE_SIZE}"
  },
  "defaults": {
    "STORAGE_REGION": "us-east-1",
    "MAX_FILE_SIZE": "10485760"
  },
  "dev": {
    "command": "pnpm dev",
    "label": "Worker"
  }
}
