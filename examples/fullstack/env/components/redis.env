; redis.env — Redis connection and config

[default]
HOST=localhost
PORT=6379
URL=redis://localhost:6379
DB=0

[staging]
HOST=${secrets.REDIS_HOST}
PORT=6379
URL=redis://${secrets.REDIS_HOST}:6379

[development]
DB=1

[production]
HOST=${secrets.REDIS_HOST}
PORT=6379
URL=redis://${secrets.REDIS_HOST}:6379
DB=0
